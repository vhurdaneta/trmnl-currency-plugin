<div class="layout layout--col gap--space-between">

  <!-- FILA 1: 4 métricas -->
  <div class="grid grid--cols-4 gap--medium">

    <div class="col">
      <div class="description">BCV USD/VES</div>
      <div class="value value--large value--tnums">{{ bcv.usd_ves | round: 2 }}</div>
      <div class="description">EUR {{ bcv.eur_ves | round: 2 }}</div>
      <div class="description">
        {% if change.bcv_usd.pct %}
          {% if change.bcv_usd.pct > 0 %}▲{% elsif change.bcv_usd.pct < 0 %}▼{% else %}→{% endif %}
          {{ change.bcv_usd.pct | abs | round: 2 }}% vs ayer
        {% else %}— vs ayer{% endif %}
      </div>
    </div>

    <div class="col">
      <div class="description">USDT AHORA</div>
      <div class="value value--large value--tnums">{{ binance_prices.buy_now.median | round: 2 }}</div>
      <div class="description">SELL {{ binance_prices.sell_now.median | round: 2 }}</div>
      <div class="description">Mediana 100 anuncios</div>
    </div>

    <div class="col">
      <div class="description">USDT PROM. DÍA</div>
      {% if binance_prices.day_avg and binance_prices.day_avg.buy_avg %}
        <div class="value value--large value--tnums">{{ binance_prices.day_avg.buy_avg | round: 2 }}</div>
        <div class="description">SELL {{ binance_prices.day_avg.sell_avg | round: 2 }}</div>
        <div class="description">
          {% if change.usdt_buy_avg.pct %}
            {% if change.usdt_buy_avg.pct > 0 %}▲{% elsif change.usdt_buy_avg.pct < 0 %}▼{% else %}→{% endif %}
            {{ change.usdt_buy_avg.pct | abs | round: 2 }}% vs ayer
          {% else %}{{ binance_prices.day_avg.count }} muestras{% endif %}
        </div>
      {% else %}
        <div class="value value--large">—</div>
        <div class="description">Recolectando...</div>
      {% endif %}
    </div>

    <div class="col">
      <div class="description">BRECHA %</div>
      <div class="value value--large value--tnums">
        {% if brecha.now_pct %}{{ brecha.now_pct | round: 2 }}%{% else %}N/D{% endif %}
      </div>
      <div class="description">
        Prom. día: {% if brecha.day_avg_pct %}{{ brecha.day_avg_pct | round: 2 }}%{% else %}N/D{% endif %}
      </div>
      <div class="description">USDT vs BCV</div>
    </div>

  </div>

  <div class="border--b-2 w--full"></div>

  <!-- FILA 2: gráfica -->
  <script src="https://trmnl.com/js/highcharts/12.3.0/highcharts.js"></script>
  <div id="bcv-chart" class="w--full"></div>
  <script type="text/javascript">
    var bcvData    = [{% for v in chart.bcv_norm %}{% unless forloop.first %},{% endunless %}{{ v | default: 0 }}{% endfor %}];
    var usdtData   = [{% for v in chart.usdt_norm %}{% unless forloop.first %},{% endunless %}{{ v | default: 0 }}{% endfor %}];
    var brechaData = [{% for v in chart.brecha_norm %}{% unless forloop.first %},{% endunless %}{{ v | default: 0 }}{% endfor %}];
    var cats       = [{% for d in chart.dates %}{% unless forloop.first %},{% endunless %}"{{ d | slice: 8, 2 }}/{{ d | slice: 5, 2 }}"{% endfor %}];
    var vmin = {{ chart.vmin | round: 0 }};
    var vmax = {{ chart.vmax | round: 0 }};

    Highcharts.chart('bcv-chart', {
      chart: {
        type: 'spline',
        height: 185,
        animation: false,
        spacing: [4, 4, 4, 4],
        backgroundColor: 'transparent'
      },
      title: { text: null },
      credits: { enabled: false },
      tooltip: { enabled: false },
      legend: {
        enabled: true,
        align: 'right',
        verticalAlign: 'top',
        itemStyle: { fontSize: '9px', fontWeight: 'normal', color: '#333' }
      },
      plotOptions: {
        series: {
          animation: false,
          enableMouseTracking: false,
          marker: { enabled: true, radius: 2 }
        }
      },
      xAxis: {
        categories: cats,
        labels: { style: { fontSize: '10px' }, step: Math.ceil(cats.length / 6) },
        tickWidth: 0,
        lineWidth: 1,
        gridLineWidth: 1,
        gridLineDashStyle: 'dot',
        gridLineColor: '#ddd',
        title: { text: null }
      },
      yAxis: [
        {
          title: { text: null },
          labels: {
            style: { fontSize: '10px' },
            formatter: function() {
              var range = vmax - vmin;
              return Math.round(vmin + (this.value / 100) * range);
            }
          },
          gridLineWidth: 1,
          gridLineDashStyle: 'shortdot',
          gridLineColor: '#ddd',
          tickAmount: 4,
          min: 0,
          max: 100
        },
        {
          title: { text: null },
          opposite: true,
          labels: {
            style: { fontSize: '9px', color: '#999' },
            formatter: function() {
              var bmin = {{ chart.brecha_min | round: 1 }};
              var bmax = {{ chart.brecha_max | round: 1 }};
              return (bmin + (this.value / 100) * (bmax - bmin)).toFixed(1) + '%';
            }
          },
          gridLineWidth: 0,
          tickAmount: 4,
          min: 0,
          max: 100
        }
      ],
      series: [
        {
          name: 'BCV',
          data: bcvData,
          yAxis: 0,
          color: '#000',
          lineWidth: 2.5,
          zIndex: 3,
          marker: { fillColor: '#000', lineColor: '#fff', lineWidth: 1 }
        },
        {
          name: 'USDT',
          data: usdtData,
          yAxis: 0,
          color: '#000',
          lineWidth: 2,
          dashStyle: 'LongDash',
          zIndex: 2,
          marker: { fillColor: '#fff', lineColor: '#000', lineWidth: 1.5 }
        },
        {
          name: 'Brecha%',
          data: brechaData,
          yAxis: 1,
          color: '#aaa',
          lineWidth: 1.5,
          dashStyle: 'ShortDot',
          zIndex: 1,
          marker: { fillColor: '#999', lineColor: '#fff', lineWidth: 1, radius: 1.5 }
        }
      ]
    });
  </script>

</div>

<div class="title_bar">
  <span class="title">BCV x USDT</span>
  <span class="instance">{{ updated_at | date: "%d/%m %H:%M" }}</span>
</div>

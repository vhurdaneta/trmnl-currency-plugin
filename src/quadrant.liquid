<div class="layout layout--col gap--space-between">

  <div class="item">
    <div class="content">
      <span class="value value--medium value--tnums">{{ bcv.usd_ves | round: 2 }}</span>
      <span class="label">BCV USD/VES</span>
    </div>
  </div>

  <div class="divider"></div>

  <div class="item">
    <div class="content">
      <span class="value value--medium value--tnums">{{ binance_prices.buy_now.median | round: 2 }}</span>
      <span class="label">USDT P2P</span>
    </div>
  </div>

  <div class="divider"></div>

  <div class="flex flex--row gap--large">
    <div class="item">
      <div class="content">
        <span class="value value--small value--tnums">
          {% if brecha.now_pct %}{{ brecha.now_pct | round: 2 }}%{% else %}N/D{% endif %}
        </span>
        <span class="label">Brecha</span>
      </div>
    </div>
    <div class="item">
      <div class="content">
        <span class="value value--small value--tnums">
          {% if change.bcv_usd.pct %}
            {% if change.bcv_usd.pct > 0 %}▲ {{ change.bcv_usd.pct | abs | round: 2 }}%
            {% elsif change.bcv_usd.pct < 0 %}▼ {{ change.bcv_usd.pct | abs | round: 2 }}%
            {% else %}→ 0.00%{% endif %}
          {% else %}—{% endif %}
        </span>
        <span class="label">Var. BCV</span>
      </div>
    </div>
  </div>

</div>

<div class="title_bar">
  <span class="title">BCV x USDT</span>
  <span class="instance">{{ updated_at | date: "%d/%m %H:%M" }}</span>
</div>
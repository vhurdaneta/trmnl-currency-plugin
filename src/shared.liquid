{% template styles %}
<style>
  .wrap { padding: 8px 10px; }
  .hdr { display:flex; justify-content:space-between; align-items:flex-end; }
  .title { font-size: 34px; font-weight: 900; line-height: 1; }
  .subtitle { font-size: 14px; margin-top: 2px; }
  .datebox { text-align:right; }
  .date { font-size: 14px; font-weight: 700; }
  .time { font-size: 12px; }

  .hr { border-top: 2px solid #000; margin: 8px 0; }

  .grid4 { display:grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .grid2 { display:grid; grid-template-columns: 1fr 1fr; gap: 10px; }

  .tile { border: 2px solid #000; padding: 6px; }
  .lab { font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: .5px; }
  .val { font-size: 20px; font-weight: 900; margin-top: 4px; }
  .sub { font-size: 12px; margin-top: 2px; }
  .muted { font-size: 12px; }

  .big { font-size: 44px; font-weight: 900; line-height: 1; }
  .mid { font-size: 22px; font-weight: 900; }

  .badge { display:inline-block; border:2px solid #000; padding: 2px 6px; font-size: 12px; font-weight: 900; }
  .foot { font-size: 12px; display:flex; justify-content:space-between; }
</style>
{% endtemplate %}

{% template header_bar %}
<div class="hdr">
  <div>
    <div class="title">{{ title }}</div>
    {% if subtitle %}<div class="subtitle">{{ subtitle }}</div>{% endif %}
  </div>

  <div class="datebox">
    <div class="date">{{ updated_at | date: "%d/%m/%Y" }}</div>
    <div class="time">{{ updated_at | date: "%H:%M" }}</div>
  </div>
</div>
{% endtemplate %}

{% template trend_badge %}
{% if pct == nil %}
  <span class="badge">—</span>
{% else %}
  {% if pct > 0 %}
    <span class="badge">▲ {{ pct | round: 2 }}%</span>
  {% elsif pct < 0 %}
    <span class="badge">▼ {{ pct | round: 2 }}%</span>
  {% else %}
    <span class="badge">→ 0.00%</span>
  {% endif %}
{% endif %}
{% endtemplate %}

{% template tile %}
<div class="tile">
  <div class="lab">{{ label }}</div>
  <div class="val">
    {% if value == nil %}N/D{% else %}{{ value | round: decimals }}{% endif %}
  </div>
  {% if subline %}
    <div class="sub">{{ subline }}</div>
  {% endif %}
  {% if pct != nil %}
    <div class="sub">{% render "trend_badge", pct: pct %}</div>
  {% endif %}
</div>
{% endtemplate %}